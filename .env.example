# Entorno de ejecución: local, development, testing o production.
APP_ENV=local

# Conexión de base de datos. Sustituir mediante el entorno del servidor.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vascor_ops_example
DB_USER=vascor_example
DB_PASSWORD=

# Opcional: URL base utilizada únicamente por las pruebas smoke.
VASCOR_SMOKE_BASE_URL=http://localhost/example/public
